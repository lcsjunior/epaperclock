{
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "f=$(jq -r '.tool_input.file_path // empty'); [[ \"$f\" =~ \\.(cpp|h|hpp)$ ]] && clang-format -i \"$f\" || true",
						"statusMessage": "Formatting C++..."
					}
				]
			}
		]
	}
}